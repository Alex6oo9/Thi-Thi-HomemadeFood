# ============================================================
# ROOT .gitignore — covers entire ThiThi_v2 monorepo
# ============================================================

# --- Secrets & environment files (NEVER commit these) -------
.env
.env.*
*.keys
*.pem
*.key
*.cert
*.p12
*.pfx
# Allow example/template env files to be committed
!.env.example
!.env.sample
!.env.template

# --- Dependencies -------------------------------------------
node_modules/
.pnp
.pnp.js

# --- Build outputs ------------------------------------------
dist/
build/
out/
.next/
.nuxt/

# --- Logs ---------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Testing ----------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# --- OS files ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- IDE / editor -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Temporary / scratch files ----------------------------------------------
*.tmp
*.temp
tmpclaude-*
nul

# --- Misc -------------------------------------------------------------------
.cache/
