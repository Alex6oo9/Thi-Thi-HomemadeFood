# ============================================================
# server/.gitignore
# ============================================================

# --- Secrets & environment files (NEVER commit these) -------
.env
.env.*
*.keys
*.pem
*.key
*.cert
!.env.example
!.env.sample

# --- Dependencies -------------------------------------------
node_modules/

# --- Build output -------------------------------------------
dist/

# --- Logs ---------------------------------------------------
*.log
logs/

# --- OS / editor --------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Temporary ----------------------------------------------
*.tmp
*.temp
