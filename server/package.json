{
  "name": "thi-thi-server",
  "version": "1.0.0",
  "description": "Backend for Thi Thi e-commerce platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:admin": "ts-node src/seed/createAdmin.ts",
    "migrate:email-verified": "ts-node-dev src/seed/migrateVerifiedUsers.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "check-orders": "ts-node src/scripts/checkOrders.ts",
    "test-orders": "ts-node src/scripts/testOrdersEndpoint.ts",
    "fix-orders": "ts-node src/scripts/fixMissingUserIds.ts",
    "fix-orphaned": "ts-node src/scripts/fixOrphanedOrders.ts",
    "check-payment-proofs": "ts-node src/scripts/checkPaymentProofs.ts",
    "db:reset": "ts-node src/scripts/resetAll.ts",
    "db:reset:users": "ts-node src/scripts/resetUsers.ts",
    "db:reset:orders": "ts-node src/scripts/resetOrders.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.3.1",
    "file-type": "^21.2.0",
    "helmet": "^8.1.0",
    "mongoose": "^7.8.7",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "resend": "^6.10.0",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitest/ui": "^4.0.17",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "vitest": "^4.0.17"
  }
}
